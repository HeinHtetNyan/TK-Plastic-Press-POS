# Copy this file to .env and fill in all values before running

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=plastic_press_db

# ── App ───────────────────────────────────────────────────────────────────────
TZ=Asia/Yangon

# JWT secret — generate a new one with: openssl rand -hex 32
SECRET_KEY=generate_with_openssl_rand_hex_32

# Token lifetime in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Security ──────────────────────────────────────────────────────────────────
# Disable API docs in production
SHOW_DOCS=false

# Comma-separated allowed frontend origins (add Cloudflare tunnel URL here)
ALLOWED_ORIGINS=http://localhost:80,https://your-tunnel.trycloudflare.com

# ── Debug (dev only, keep false in production) ────────────────────────────────
DB_ECHO=false

# ── Cloudflare R2 backup upload ───────────────────────────────────────────────
# Account ID: found at dash.cloudflare.com → R2 → Overview (right sidebar)
R2_ACCOUNT_ID=your_cloudflare_account_id

# API token with R2 read+write: dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Bucket name (create at dash.cloudflare.com → R2 → Create bucket)
R2_BUCKET=your-bucket-name
